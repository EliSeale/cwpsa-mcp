# Key Vault URI (required — the ONLY credential in env; §12.1 / §12.2)
# DefaultAzureCredential (Managed Identity in prod, az login locally) reads secrets via RBAC.
KEY_VAULT_URI=https://your-vault.vault.azure.net/
# Legacy alias also accepted: KEY_VAULT_URL=...

# ---------------------------------------------------------------------------
# Local dev (CW_LOCAL_SECRETS=1): read secrets from env vars instead of Key Vault.
# Secret name to env var: replace dashes with underscores, uppercase.
# ---------------------------------------------------------------------------
# CW_LOCAL_SECRETS=1

# Key Vault secret: CWPSA-company-id          -> env: CWPSA_COMPANY_ID
# CWPSA_COMPANY_ID=mettle

# Key Vault secret: CWPSA-client-id           -> env: CWPSA_CLIENT_ID
# CWPSA_CLIENT_ID=your-integration-app-id

# Key Vault secret: CWPSA-Integrator-Username -> env: CWPSA_INTEGRATOR_USERNAME
# CWPSA_INTEGRATOR_USERNAME=your-integrator-login-username

# Key Vault secret: CWPSA-Integrator-Password -> env: CWPSA_INTEGRATOR_PASSWORD
# CWPSA_INTEGRATOR_PASSWORD=your-integrator-login-password

# ---------------------------------------------------------------------------
# Three-leg credential model (§10.4/§10.6):
#   Hop 1  — member lookup  : API member keys below  (x-cw-usertype: member)
#   Hop 2  — token mint     : CWPSA-Integrator-* above (x-cw-usertype: integrator)
#   Hop 3+ — act as member  : minted per-user keys (4-hr, cached by broker)
# ---------------------------------------------------------------------------

# Key Vault secret: cw-publickey-01-mcp  -> env: CW_PUBLICKEY_01_MCP
# Used ONLY for Hop 1 (GET /system/members to resolve Entra UPN -> CW member).
# CW_PUBLICKEY_01_MCP=your-api-member-public-key

# Key Vault secret: cw-privatekey-01-mcp -> env: CW_PRIVATEKEY_01_MCP
# CW_PRIVATEKEY_01_MCP=your-api-member-private-key

# ConnectWise instance URL (no trailing slash)
# CW_BASE_URL=https://connect.verveit.com

# Skip vocabulary bootstrap for fast local stdio launches
# CW_LOAD_VOCABULARY=0

# Path to registry artifact (default: registry.json in CWD)
# CW_REGISTRY_PATH=registry.json

# MCP transport: http (Container Apps) or unset (stdio / local)
# MCP_TRANSPORT=http
# MCP_HOST=0.0.0.0
# MCP_PORT=8080

# Redis for idempotency store and per-user token cache (Phase 2+)
# REDIS_URL=redis://localhost:6379/0

# OTel / Application Insights connection string
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# Write kill-switch: 1 to disable all mutations globally
# CW_WRITES_DISABLED=1

# OKF business-knowledge bundle path
# OKF_BUNDLE_PATH=business-knowledge

# Edge self-protection limits (S8.3)
# CW_EDGE_RATE_PER_MIN=120
# CW_EDGE_CONCURRENCY=5
# CW_EDGE_GLOBAL_RATE=800
# CW_EDGE_SESSION_BUDGET=500
